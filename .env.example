# Aplicação
APP_URL=http://localhost:3000

# IA - Provider único (desenvolvimento local)
# fake: usa respostas locais determinísticas e não requer chave.
# groq | openrouter | gemini: usa a respectiva chave de API no servidor.
AI_PROVIDER=fake

# IA - Multi-provider (produção)
# Quando definido, AI_PROVIDERS tem prioridade sobre AI_PROVIDER.
# Providers ativos separados por vírgula, em ordem de prioridade de fallback.
# AI_PROVIDERS=gemini,groq,openrouter
# AI_PROVIDER_WEIGHTS=5,3,2

# Chaves de API dos providers (server-side, nunca use NEXT_PUBLIC_)
GROQ_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# Configuração do orquestrador (opcionais, defaults sensatos)
# AI_CIRCUIT_BREAKER_THRESHOLD=3
# AI_CIRCUIT_BREAKER_RECOVERY_MS=30000

# Supabase - será usado a partir da milestone de autenticação/persistência.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
