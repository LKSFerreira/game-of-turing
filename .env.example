# Aplicação
APP_URL=http://localhost:3000

# IA
# fake: usa respostas locais determinísticas e não requer chave.
# groq: usa GROQ_API_KEY no servidor.
# openrouter: usa OPENROUTER_API_KEY no servidor.
# gemini: reservado para adaptador futuro usando GEMINI_API_KEY no servidor.
AI_PROVIDER=fake
GROQ_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# Supabase - será usado a partir da milestone de autenticação/persistência.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
